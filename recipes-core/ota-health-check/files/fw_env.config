# fw_env.config for LS1046A
# Maps fw_setenv/fw_printenv to per-core U-Boot environment on flash.
#
# !! ADJUST THESE VALUES to match your actual flash partition layout !!
#
# MTD device        Offset    Env size  Sector size
/dev/mtd2           0x0000    0x2000    0x10000
# Redundant env copy
/dev/mtd2           0x10000   0x2000    0x10000
